# ===================================================================
# The Audiopheliac - Production .gitignore
# ===================================================================

# -----------------------------
# OS / System Files
# -----------------------------
.DS_Store
Thumbs.db
desktop.ini

# -----------------------------
# Editor / IDE
# -----------------------------
.vscode/
.idea/
*.code-workspace

# -----------------------------
# Environment / Secrets
# -----------------------------
.env
.env.*
/config/
!config/music_sources.json
*.key
*.pem

# -----------------------------
# Python
# -----------------------------
.venv/
env/
venv/
__pycache__/
*.pyc

# -----------------------------
# Ableton Live / Audio Production
# -----------------------------
# Cache + temp (critical to ignore)
Ableton Cache/
Ableton Temp/
*.asd

# Freeze / render junk
Freeze/
*.wav.tmp
*.aif.tmp

# -----------------------------
# Sample Libraries (DO NOT TRACK)
# -----------------------------
Splice Samples/
Samples/
*.flac
*.wav
*.aiff

# -----------------------------
# Generated Data (regenerable, never tracked)
# -----------------------------
data/**
!data/**/.gitkeep

# -----------------------------
# NAS / Sync / Cloud Garbage
# -----------------------------
.tmp.driveupload/
.tmp.drivedownload/
*.sync
*.qsync

# -----------------------------
# Logs
# -----------------------------
*.log

# -----------------------------
# Optional (uncomment if needed)
# -----------------------------
# Renders/
# Exports/
# Stems/

# Development working files (not tracked)
_dev/
