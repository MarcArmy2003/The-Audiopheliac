---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Home">

  <!-- ============================================================
       HERO — two-column
       ============================================================ -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-text">
        <p class="hero-eyebrow">Home hi-fi, anti-pretense</p>
        <h1 class="hero-headline">
          Where signal flow meets <span class="grad">soul.</span>
        </h1>
        <p class="hero-lede">
          A lifestyle brand built on the credibility of an actual signal chain. Studio
          monitoring, vinyl rotations across four listening zones, AI-assisted releases on
          Suno, and gear reviews from rigs we run nightly.
        </p>
        <div class="hero-ctas">
          <a href="/studio" class="cta cta--hero">Step into the studio</a>
          <a href="/journal" class="cta cta--ghost">Read the journal</a>
        </div>
      </div>
      <div class="hero-mark-wrap">
        <img
          class="hero-mark"
          src="/brand/audiopheliac-mark.jpg"
          alt="The Audiopheliac — rainbow spectrum vinyl mark"
          width="480"
          height="480"
        />
      </div>
    </div>
  </section>

  <!-- ============================================================
       MOTTO
       ============================================================ -->
  <section class="motto-row">
    <p class="motto-text">&ldquo;Rock &lsquo;n&rsquo; roll. Deal with it.&rdquo;</p>
    <p class="motto-attr">After Bret Easton Ellis, <em>The Rules of Attraction</em></p>
  </section>

  <!-- ============================================================
       ZONES — four listening rooms
       ============================================================ -->
  <section class="section">
    <div class="section__head">
      <div>
        <p class="section__eyebrow">The setup</p>
        <h2>Four zones. One signal chain.</h2>
      </div>
      <a href="/studio" class="cta cta--ghost">See the full chain</a>
    </div>
    <div class="grid zone-grid">
      <a class="card zone-card" href="/studio#family-room">
        <span class="zone-badge zone-badge--fr">FR</span>
        <div>
          <h3>Family Room</h3>
          <p>Technics SL-1200MK2 into a Pro-Ject phono preamp, through a Yamaha R-N800A into Polk ES60s. Wireless distribution hub for Studio, Lanai, and Garage via 1Mii TX.</p>
        </div>
      </a>
      <a class="card zone-card" href="/studio#studio">
        <span class="zone-badge zone-badge--st">ST</span>
        <div>
          <h3>Studio</h3>
          <p>M-Audio AIR Hub into a Rolls MX28 Mini-Mix, feeding Yamaha HS7s and a JBL LSR310S sub. AT-LP120XUSB via Schiit Mani II. Roon + Ableton Live 12 Suite on GDMARCHE.</p>
        </div>
      </a>
      <a class="card zone-card" href="/studio#lanai">
        <span class="zone-badge zone-badge--ln">LN</span>
        <div>
          <h3>Lanai</h3>
          <p>Roon Chromecast primary endpoint. 1Mii wireless receiver into a Schiit SYS switcher into a Bose 3&middot;2&middot;1. Samsung eARC extracted via J-Tech adapter for TV audio.</p>
        </div>
      </a>
      <a class="card zone-card" href="/studio#garage">
        <span class="zone-badge zone-badge--gr">GR</span>
        <div>
          <h3>Garage</h3>
          <p>Bose SoundTouch Genius. Bluetooth from phone or 3.5mm line-in. Amazon Echo as a parallel endpoint. Yamaha R-N800A Bluetooth when signal allows.</p>
        </div>
      </a>
    </div>
  </section>

  <!-- ============================================================
       VINYL
       ============================================================ -->
  <section class="section">
    <div class="section__head">
      <div>
        <p class="section__eyebrow">The collection</p>
        <h2>Vinyl on the platter.</h2>
      </div>
      <a href="/vinyl" class="cta cta--ghost">See full collection</a>
    </div>
    <div class="grid grid--3">
      <a class="card vinyl-card" href="/vinyl#collection">
        <p class="vinyl-label">Collection</p>
        <h3>Curated, growing.</h3>
        <p>Median Discogs pricing tracked. Country, classic rock, blues-rock, and hard rock anchors. Searched deliberately, not accumulated passively.</p>
        <span class="card__more">Browse the stack &rarr;</span>
      </a>
      <a class="card vinyl-card" href="/vinyl#wishlist">
        <p class="vinyl-label">Wishlist</p>
        <h3>What&rsquo;s next on the platter.</h3>
        <p>Titles we're tracking on Discogs before they press again or prices peak. Active research list, not idle bookmarks.</p>
        <span class="card__more">See what&rsquo;s queued &rarr;</span>
      </a>
      <a class="card vinyl-card" href="/vinyl#recent">
        <p class="vinyl-label">Recent adds</p>
        <h3>What just came in.</h3>
        <p>Zach Bryan, Shaboozey, Gavin Adcock, The Red Clay Strays. Country and roots-adjacent, sequenced for the room.</p>
        <span class="card__more">Latest arrivals &rarr;</span>
      </a>
    </div>
  </section>

  <!-- ============================================================
       COCKPIT PREVIEW
       ============================================================ -->
  <section class="section cockpit-section">
    <div class="cockpit-inner">
      <div class="cockpit-text">
        <p class="section__eyebrow">Local control</p>
        <h2>The Cockpit.</h2>
        <p class="lede">
          A private web app running on the local network. Roon library browse and transport
          across all zones. Yamaha receiver controls&mdash;power, source, volume, Net Radio presets.
          Runs at <code class="kbd">127.0.0.1:5000</code> on GDMARCHE.
        </p>
        <a href="/cockpit" class="cta" style="margin-top: var(--sp-5); display: inline-flex;">Open Cockpit</a>
      </div>
      <div class="cockpit-widget">
        <div class="cockpit-mock">
          <div class="cm-header">
            <img src="/brand/audiopheliac-mark.jpg" alt="" width="28" height="28" style="border-radius:50%; object-fit:contain;" />
            <span>Cockpit</span>
          </div>
          <div class="cm-now-playing">
            <div class="cm-vinyl-art"></div>
            <div class="cm-track-info">
              <p class="cm-track">Now Playing</p>
              <p class="cm-artist muted">Select a zone to begin</p>
            </div>
          </div>
          <div class="cm-transport">
            <button class="t-btn" aria-label="Previous" tabindex="-1">&#9198;</button>
            <button class="t-btn t-btn--primary" aria-label="Play" tabindex="-1">&#9654;</button>
            <button class="t-btn" aria-label="Next" tabindex="-1">&#9197;</button>
          </div>
          <div class="cm-zones">
            <div class="cm-zone">Family Room &mdash; Yamaha</div>
            <div class="cm-zone cm-zone--active">Studio &middot; AIR HUB</div>
            <div class="cm-zone">Lanai - TV</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       TOOLS
       ============================================================ -->
  <section class="section">
    <div class="section__head">
      <div>
        <p class="section__eyebrow">Internal tools</p>
        <h2>Built for the signal chain.</h2>
      </div>
    </div>
    <div class="grid tools-grid">
      <div class="card tool-card">
        <div class="tool-head">
          <h3>File Format Converter</h3>
          <span class="tag">Active</span>
        </div>
        <p>Convert WAV, FLAC, MP3, AIFF, and OGG between formats. Normalize loudness to streaming targets. Batch process without breaking Spotify&rsquo;s Local Files index.</p>
      </div>
      <div class="card tool-card">
        <div class="tool-head">
          <h3>Music Indexer</h3>
          <span class="tag tag--bronze">Running</span>
        </div>
        <p>Crawls <code class="kbd">\\NAS87828E\Music</code> and builds a structured library index. 13,450 tracks indexed. Source of truth for Spotify gap analysis.</p>
      </div>
      <div class="card tool-card">
        <div class="tool-head">
          <h3>Gap Reporter</h3>
          <span class="tag tag--steel">Scheduled</span>
        </div>
        <p>Compares local library against Spotify saved tracks. Surfaces missing tracks and unindexed local files. Output: <code class="kbd">spotify_missing_tracks.txt</code>.</p>
      </div>
      <div class="card tool-card">
        <div class="tool-head">
          <h3>Discogs Sync</h3>
          <span class="tag tag--steel">Planned</span>
        </div>
        <p>Collection and wantlist sync from the Discogs API. Median pricing tracked per release. Intake via <code class="kbd">Vinyl_Collection_Update_Queue.csv</code>.</p>
      </div>
    </div>
  </section>

  <!-- ============================================================
       PLAYLISTS
       ============================================================ -->
  <section class="section">
    <div class="section__head">
      <div>
        <p class="section__eyebrow">Programmed listening</p>
        <h2>The Audiopheliac presents.</h2>
      </div>
      <a href="/music" class="cta cta--ghost">All playlists</a>
    </div>
    <div class="grid pl-grid">
      <a class="card pl-card" href="/music">
        <div class="pl-art pl-art--country" role="img" aria-label="Country / Roots / Americana"></div>
        <div class="pl-info">
          <p class="pl-eyebrow">Country &middot; Roots &middot; Americana</p>
          <h3>Friday Night at the BR</h3>
          <p>Zach Bryan, Tyler Childers, Sturgill Simpson, Cody Jinks, Colter Wall. Structured for long sessions, sequenced for the room.</p>
        </div>
      </a>
      <a class="card pl-card" href="/music">
        <div class="pl-art pl-art--rock" role="img" aria-label="Classic Rock / Hard Rock / Blues-Rock"></div>
        <div class="pl-info">
          <p class="pl-eyebrow">Classic Rock &middot; Hard Rock &middot; Blues-Rock</p>
          <h3>The Riff Cannon</h3>
          <p>Zeppelin, AC/DC, SRV, Allman Brothers, Black Keys. Bass-heavy, room-filling, no filler.</p>
        </div>
      </a>
      <a class="card pl-card" href="/music">
        <div class="pl-art pl-art--suno" role="img" aria-label="AI Music / Suno v5.5"></div>
        <div class="pl-info">
          <p class="pl-eyebrow">AI Music &middot; Suno v5.5</p>
          <h3>First Tracks</h3>
          <p>Original Audiopheliac releases on Suno. Commercial-use Premier plan. Early experiments and first full productions.</p>
        </div>
      </a>
      <a class="card pl-card" href="/music">
        <div class="pl-art pl-art--deep" role="img" aria-label="Deep Cuts / Album Tracks"></div>
        <div class="pl-info">
          <p class="pl-eyebrow">Deep Cuts &middot; Album Tracks</p>
          <h3>B-Side Protocol</h3>
          <p>Recognizable artists, less-played tracks. Quality deep cuts, no crate-digging obscurity.</p>
        </div>
      </a>
    </div>
  </section>

  <!-- ============================================================
       MANIFESTO
       ============================================================ -->
  <section class="section manifesto">
    <div class="manifesto-inner">
      <p class="section__eyebrow">About this signal</p>
      <h2>The Audiopheliac exists because most audio content is either too credentialed or too casual.</h2>
      <div class="manifesto-body">
        <p>
          This isn&rsquo;t a publication for people who spent $40,000 on cable lifters. It&rsquo;s for the person
          who bought a used Technics, read every spec sheet before pulling the trigger on monitors,
          and still can&rsquo;t explain to their family why the sub needed its own dedicated outlet.
        </p>
        <p>
          We program for the room. We sequence for long sessions. We review gear we actually run.
          We release music under our own name. The signal chain is the credibility&mdash;not a credential.
        </p>
        <p class="manifesto-motto">&ldquo;Where every cable, waveform, and decibel earns its keep.&rdquo;</p>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ============================================================
     HERO
     ============================================================ */
  .hero {
    padding: var(--sp-9) 0 var(--sp-8);
    border-bottom: 1px solid var(--surface-edge);
    margin-bottom: var(--sp-6);
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: var(--sp-8);
    align-items: center;
  }
  .hero-eyebrow {
    font-family: var(--font-mono);
    font-size: var(--fs-100);
    letter-spacing: 0.28em;
    color: var(--spectrum-2);
    text-transform: uppercase;
    margin: 0 0 var(--sp-4);
  }
  .hero-headline {
    font-size: clamp(var(--fs-700), 7vw, var(--fs-max));
    line-height: 0.95;
    margin: 0 0 var(--sp-5);
    color: var(--paper);
    letter-spacing: 0.01em;
  }
  .grad {
    background: var(--spectrum-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .hero-lede {
    font-size: var(--fs-400);
    color: var(--n-300);
    max-width: 40rem;
    line-height: var(--lh-normal);
    margin: 0 0 var(--sp-6);
  }
  .hero-ctas {
    display: flex;
    gap: var(--sp-4);
    flex-wrap: wrap;
  }
  .hero-mark-wrap {
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .hero-mark {
    width: 100%;
    max-width: 420px;
    aspect-ratio: 1;
    border-radius: 50%;
    object-fit: contain;
    filter: drop-shadow(0 0 48px rgba(248, 233, 31, 0.18));
  }

  /* ============================================================
     MOTTO
     ============================================================ */
  .motto-row {
    text-align: center;
    padding: var(--sp-7) 0;
    border-top: 1px solid var(--surface-edge);
    border-bottom: 1px solid var(--surface-edge);
    margin-bottom: var(--sp-4);
  }
  .motto-text {
    font-family: var(--font-display);
    font-size: var(--fs-600);
    color: var(--paper);
    letter-spacing: 0.03em;
    margin: 0 0 var(--sp-2);
  }
  .motto-attr {
    font-family: var(--font-mono);
    font-size: var(--fs-100);
    letter-spacing: 0.16em;
    color: var(--n-400);
    text-transform: uppercase;
    margin: 0;
  }

  /* ============================================================
     ZONES
     ============================================================ */
  .zone-grid { grid-template-columns: repeat(auto-fit, minmax(22rem, 1fr)); }
  .zone-card {
    display: flex;
    gap: var(--sp-4);
    align-items: flex-start;
    color: var(--paper);
    border-bottom: none;
  }
  .zone-card h3 { margin: 0 0 var(--sp-2); font-size: var(--fs-500); color: var(--paper); }
  .zone-card p  { color: var(--n-300); margin: 0; font-size: var(--fs-200); line-height: var(--lh-normal); }
  .zone-badge {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: var(--r-md);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: var(--fs-100);
    font-weight: 700;
    letter-spacing: 0.06em;
  }
  .zone-badge--fr { background: rgba(248, 233, 31, 0.10); color: var(--spectrum-1); border: 1px solid rgba(248, 233, 31, 0.28); }
  .zone-badge--st { background: rgba(65, 217, 154, 0.10); color: var(--spectrum-2); border: 1px solid rgba(65, 217, 154, 0.28); }
  .zone-badge--ln { background: rgba(10, 190, 211, 0.10); color: var(--cyan);       border: 1px solid rgba(10, 190, 211, 0.28); }
  .zone-badge--gr { background: rgba(194, 76, 200, 0.10); color: var(--magenta);    border: 1px solid rgba(194, 76, 200, 0.28); }

  /* ============================================================
     VINYL
     ============================================================ */
  .vinyl-card {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    color: var(--paper);
    border-bottom: none;
  }
  .vinyl-label {
    font-family: var(--font-mono);
    font-size: var(--fs-100);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--spectrum-1);
    margin: 0;
  }
  .vinyl-card h3 { margin: 0; font-size: var(--fs-500); }
  .vinyl-card p  { color: var(--n-300); margin: 0; font-size: var(--fs-200); line-height: var(--lh-normal); }
  .card__more {
    margin-top: auto;
    padding-top: var(--sp-4);
    color: var(--spectrum-2);
    font-family: var(--font-mono);
    font-size: var(--fs-100);
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  /* ============================================================
     COCKPIT PREVIEW
     ============================================================ */
  .cockpit-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-8);
    align-items: center;
  }
  .cockpit-text h2 { margin: var(--sp-3) 0 var(--sp-4); font-size: var(--fs-700); }
  .cockpit-widget { display: flex; justify-content: center; }

  .cockpit-mock {
    background: var(--surface);
    border: 1px solid var(--surface-edge);
    border-radius: var(--r-lg);
    padding: var(--sp-5);
    width: 100%;
    max-width: 340px;
    font-size: var(--fs-200);
  }
  .cm-header {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    margin-bottom: var(--sp-4);
    color: var(--paper);
    font-family: var(--font-display);
    font-size: var(--fs-300);
    letter-spacing: 0.04em;
  }
  .cm-now-playing {
    display: flex;
    gap: var(--sp-4);
    align-items: center;
    margin-bottom: var(--sp-4);
    padding: var(--sp-4);
    background: var(--surface-2);
    border-radius: var(--r-md);
  }
  .cm-vinyl-art {
    width: 52px;
    height: 52px;
    flex-shrink: 0;
    border-radius: 50%;
    background:
      radial-gradient(circle at 50% 50%, var(--ink) 26%, transparent 27%),
      repeating-radial-gradient(circle at 50% 50%,
        transparent 0, transparent 3px,
        rgba(255,255,255,0.04) 3px, rgba(255,255,255,0.04) 4px
      ),
      #1a1a20;
    border: 2px solid rgba(248, 233, 31, 0.20);
  }
  .cm-track-info { min-width: 0; }
  .cm-track  { color: var(--paper); margin: 0 0 var(--sp-1); font-weight: 600; font-size: var(--fs-200); }
  .cm-artist { margin: 0; font-size: var(--fs-100); }
  .cm-transport {
    display: flex;
    justify-content: center;
    gap: var(--sp-3);
    margin-bottom: var(--sp-4);
  }
  .t-btn {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid var(--surface-edge);
    background: var(--surface-2);
    color: var(--n-300);
    cursor: default;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--fs-200);
  }
  .t-btn--primary {
    background: var(--spectrum-1);
    color: var(--ink);
    border-color: var(--spectrum-1);
    width: 44px;
    height: 44px;
    font-size: var(--fs-300);
  }
  .cm-zones { display: flex; flex-direction: column; gap: var(--sp-2); }
  .cm-zone {
    padding: var(--sp-2) var(--sp-3);
    border-radius: var(--r-sm);
    background: var(--surface-2);
    color: var(--n-400);
    font-family: var(--font-mono);
    font-size: var(--fs-100);
    letter-spacing: 0.10em;
  }
  .cm-zone--active {
    background: rgba(248, 233, 31, 0.07);
    color: var(--spectrum-1);
    border: 1px solid rgba(248, 233, 31, 0.20);
  }

  /* ============================================================
     TOOLS
     ============================================================ */
  .tools-grid { grid-template-columns: repeat(auto-fit, minmax(22rem, 1fr)); }
  .tool-card { color: var(--paper); }
  .tool-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: var(--sp-3);
    gap: var(--sp-3);
  }
  .tool-card h3 { margin: 0; font-size: var(--fs-400); }
  .tool-card p  { color: var(--n-300); margin: 0; font-size: var(--fs-200); line-height: var(--lh-normal); }

  /* ============================================================
     PLAYLISTS
     ============================================================ */
  .pl-grid { grid-template-columns: repeat(auto-fit, minmax(22rem, 1fr)); }
  .pl-card {
    display: flex;
    gap: var(--sp-4);
    align-items: flex-start;
    color: var(--paper);
    border-bottom: none;
  }
  .pl-art {
    flex-shrink: 0;
    width: 64px;
    height: 64px;
    border-radius: var(--r-md);
    position: relative;
    overflow: hidden;
  }
  .pl-art::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background:
      radial-gradient(circle at 50% 50%, rgba(10,10,11,0.9) 28%, transparent 29%),
      repeating-radial-gradient(circle at 50% 50%,
        transparent 0, transparent 3px,
        rgba(255,255,255,0.06) 3px, rgba(255,255,255,0.06) 4px
      );
  }
  .pl-art--country { background: linear-gradient(135deg, #F8E91F, #99E257); }
  .pl-art--rock    { background: linear-gradient(135deg, #C24CC8, #5E54D4); }
  .pl-art--suno    { background: linear-gradient(135deg, #0ABED3, #0F82DF); }
  .pl-art--deep    { background: linear-gradient(135deg, #41D99A, #0ABED3); }
  .pl-eyebrow {
    font-family: var(--font-mono);
    font-size: var(--fs-100);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--spectrum-2);
    margin: 0 0 var(--sp-2);
  }
  .pl-info h3 { margin: 0 0 var(--sp-2); font-size: var(--fs-400); }
  .pl-info p  { color: var(--n-300); margin: 0; font-size: var(--fs-200); line-height: var(--lh-normal); }

  /* ============================================================
     MANIFESTO
     ============================================================ */
  .manifesto-inner { max-width: var(--content-narrow); }
  .manifesto h2 { margin: var(--sp-3) 0 var(--sp-6); font-size: var(--fs-600); }
  .manifesto-body p {
    color: var(--n-300);
    font-size: var(--fs-400);
    line-height: var(--lh-loose);
    margin: 0 0 var(--sp-5);
  }
  .manifesto-motto {
    font-family: var(--font-display);
    font-size: var(--fs-500);
    color: var(--spectrum-1);
    letter-spacing: 0.02em;
    margin: 0;
    opacity: 0.90;
  }

  /* ============================================================
     RESPONSIVE
     ============================================================ */
  @media (max-width: 860px) {
    .hero-inner {
      grid-template-columns: 1fr;
    }
    .hero-mark-wrap { display: none; }
    .cockpit-inner  { grid-template-columns: 1fr; }
    .cockpit-widget { display: none; }
  }
  @media (max-width: 600px) {
    .motto-text { font-size: var(--fs-500); }
    .hero-headline { font-size: var(--fs-700); }
  }
</style>
